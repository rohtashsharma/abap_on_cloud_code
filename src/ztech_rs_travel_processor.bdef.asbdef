projection;
strict ( 2 );

define behavior for ZTECH_RS_TRAVEL_PROCESSOR alias Travel
{
  use create;
  use update;
  use delete;

  use association _Booking { create; }
}

define behavior for ZTECH_RS_BOOKING_PROCESSOR //alias <alias_name>
{
  use update;
  use delete;

  use association _Travel;
  use association _BookingSuppl { create; }
}

define behavior for ZTECH_RS_BOOKSUPP_PROCESSOR alias BookSupppl
{
  use update;
  use delete;

  use association _Travel;
  use association _Booking;
}